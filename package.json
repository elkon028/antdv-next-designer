{
    "name": "@form-create/antdv-next-designer",
    "version": "3.5.0",
    "type": "module",
    "description": "antdv-next 版本Vue低代码可视化表单设计器，可以通过拖拽的方式快速创建表单，提高开发者对表单的开发效率。",
    "unpkg": "./dist/index.umd.js",
    "jsdelivr": "./dist/index.umd.js",
    "typings": "./types/index.d.ts",
    "main": "./dist/index.umd.js",
    "module": "./dist/index.es.js",
    "scripts": {
        "clean": "rimraf dist/",
        "dev": "vite --config ./vite.config.dev.js",
        "build": "vite build --config ./vite.config.build.js && vite build --config ./vite.config.form.js",
        "build:form": "vite build --config ./vite.config.form.js",
        "build:locale": "gulp -f gulpfile.js",
        "build:preview": "vite build --config ./vite.config.preview.js"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "AI",
        "可视化表单设计器",
        "form-create",
        "form-builder",
        "form-designer",
        "draggable",
        "form",
        "components",
        "vue",
        "antdv-next",
        "json-form",
        "dynamic-form"
    ],
    "files": [
        "README.md",
        "package.json",
        "LICENSE",
        "src",
        "types",
        "dist",
        "locale"
    ],
    "author": "elkon",
    "license": "MIT",
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.2.4",
        "@vitejs/plugin-vue-jsx": "^4.2.0",
        "@vue/babel-plugin-jsx": "^1.0.7",
        "@vue/cli-plugin-babel": "^4.5.13",
        "@vue/cli-service": "^4.5.3",
        "@vue/compiler-sfc": "^3.0.11",
        "babel-eslint": "^10.1.0",
        "cssnano": "^8.0.2",
        "execa": "^9.6.1",
        "gulp": "^4.0.2",
        "html-webpack-plugin": "^4.3.0",
        "jsonlint-mod": "^1.7.6",
        "lint-staged": "^10.2.11",
        "rimraf": "^3.0.2",
        "rollup-plugin-visualizer": "^7.0.1",
        "vite": "^6.4.3",
        "vite-plugin-banner": "^0.8.1",
        "vite-plugin-css-injected-by-js": "^4.0.1"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "lint-staged": {
        "*.{js,jsx,vue}": [
            "eslint --fix",
            "git add"
        ]
    },
    "peerDependencies": {
        "vue": "^3.5"
    },
    "dependencies": {
        "@form-create/antdv-next": "^3.3.1",
        "@form-create/component-wangeditor": "^3.3.0",
        "@form-create/utils": "^3.3.0",
        "antdv-next": "^1.3.7",
        "codemirror": "^6.65.7",
        "js-beautify": "^1.15.1",
        "marked": "^17.0.0",
        "signature_pad": "^5.0.10",
        "sortablejs": "1.14.0",
        "vuedraggable": "4.1.0"
    }
}
